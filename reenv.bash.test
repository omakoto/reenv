#!/bin/bash

unset _reenv_file_base _reenv_file_cur _reenv_file_unset_base _reenv_file_unset_cur _reenv_initialized _reenv_verbose REENV_SKIP

. "$(dirname "$0")/reenv.bash"

num_tests=0
num_failure=0

DIFF=/usr/bin/diff
SED=$(type -p sed || echo /bin/sed)

function green() {
    echo -en "\033[0;32m${*}\033[0m"
}

function red() {
    echo -en "\033[0;31m${*}\033[0m"
}

function run_test() {
    (( ++num_tests))

    local label="$1"

    local content
    IFS='' read -r -d '' content

    local run="${content%%$'\n'=== expected ===*}"
    local expected="${content#*=== expected ===}"
    expected="${expected#?}"

    echo "================"
    green "Test:"
    echo " $label"
    echo "----------------"

    # Normalize script name and line numbers in errors to prevent test failures when the
    # test script path or line counts change. Absolute path to sed is needed because some
    # tests override PATH (e.g. "Precheck fail").
    local actual="$(eval "$run" 2>&1 | $SED -E -e "s|.*/?reenv.bash.test: line [0-9]+:|reenv.bash.test: line ???:|g" -e "/^Dumping/d")"

    $DIFF -Z -u <(echo -n "$expected") <(echo -n "$actual")
    local rc=$?
    if (( $rc == 0 )); then
        green "PASSED"
        echo
    else
        (( ++num_failure))
        red "FAILED!"
        echo " Actual result:"
        echo "#################################################################"
        echo "$actual"
        echo "#################################################################"
    fi
}

export _reenv_quiet=1

# ==========================================================
run_test "Call without base" <<'EOF'
reenv-cap
echo $?
=== expected ===
reenv: Use reenv-base to capture the base line environment first!
1
EOF


# ==========================================================
_reenv_quiet=0 run_test "No quiet base" <<'EOF'
reenv-base
echo $?
=== expected ===
reenv: Captured baseline. Use reenv-cap to print the delta.
0
EOF

# ==========================================================
run_test "No env change" <<'EOF'
reenv-base
echo $?
reenv-cap
echo $?
=== expected ===
0
0
EOF

# ==========================================================
run_test "Basic env change" <<'EOF'
changed=orig
reenv-base
echo $?

aaa="abc"
export XXX="xyz def"
changed=new

reenv-cap
echo $?
=== expected ===
0
#v:XXX
declare -g -x XXX="xyz def"
###REENV###
#v:aaa
declare -g -- aaa="abc"
###REENV###
#v:changed
declare -g -- changed="new"
###REENV###
0
EOF

# ==========================================================
run_test "Multiline variable containing declare" <<'EOF'
reenv-base
echo $?

export multiline="first line
declare is a command
third line"

reenv-cap
echo $?
=== expected ===
0
#v:multiline
declare -g -x multiline=$'first line\ndeclare is a command\nthird line'
###REENV###
0
EOF

# ==========================================================
run_test "Complex change" <<'EOF'

function a() {
    echo ok
}
alias AAA="
echo OK
"

reenv-base
echo $?

function a() { echo not ok; }
function b() {
    echo "ok😄"
}
var="X
Y
Z"

alias BBB="
    echo BBB
"

reenv-cap
echo $?
=== expected ===
0
#a:BBB(alias)
alias BBB='
    echo BBB
'
###REENV###
#f:a()
a () 
{ 
    echo not ok
}
###REENV###
#f:b()
b () 
{ 
    echo "ok😄"
}
###REENV###
#v:var
declare -g -- var=$'X\nY\nZ'
###REENV###
0
EOF

# ==========================================================
run_test "Deletion" <<'EOF'
var1=aaa
var2=bbb
function func1() { echo ok; }
function func2() { echo ok; }
alias alias1="echo ok"
alias alias2="echo ok"

reenv-base
echo $?

unset -v var1
var2=bbb
var3=ccc
unset -f func1
unalias alias2
function func2() { echo not ok; }
function func3() { echo not ok; }

reenv-cap
echo $?
=== expected ===
0
unalias alias2
###REENV###
unset -f func1
###REENV###
unset -v var1
###REENV###
#f:func2()
func2 () 
{ 
    echo not ok
}
###REENV###
#f:func3()
func3 () 
{ 
    echo not ok
}
###REENV###
#v:var3
declare -g -- var3="ccc"
###REENV###
0
EOF

# ==========================================================
run_test "Actually apply" <<'EOF'
shopt -s expand_aliases # Need this to execute aliases in here

var1=aaa
var2="b
b
b"
function func1() { echo ok; }
function func2() {
    echo ok
}

# Also try exporting the functions
export -f func1
export -f func2

alias alias1="echo alias1"
alias alias2="echo alias2"

reenv-base
echo $?

# Update the env in subshell, and dump the diff.
(
    echo "# Capture in subshell!"
    unset -v var1
    var2=bbb
    var3="c
c
c"
    unset -f func1
    function func2() { echo not ok; }
    function func3() { echo not ok; }


    # Export a new function.
    function func4() { echo not ok; }
    export -f func4

    # Change aliases
    unalias alias1
    alias alias3="echo alias3"

    reenv-cap > /tmp/reenv-test.sh
    echo "--- Delta in subshell START ---"
    cat /tmp/reenv-test.sh
    echo $?
    echo "--- Delta in subshell END ---"
)

echo "# Capture again, which should be empty"
reenv-cap
echo $?

echo "# Apply again!"
# Apply in a function, to make sure variables are declared as global.
# The reenv_ function name prefix is to avoid printing this method
# in a subsequent dump.
function reenv_test_apply_func() {
    . /tmp/reenv-test.sh
    echo $?
}
reenv_test_apply_func

echo "# Capture after apply"
# Now, this should print the same delta.
reenv-cap
echo $?

# Try calling func2 and func3
echo "Calling func2"
func2

echo "Calling func3"
func3

echo "Calling func4"
func4

# func2 is exported, so it is visible from child procs
echo "Calling func2 (exported)"
bash -c "func2"

# func3 is exported, so it is not visible.
echo "Calling func2 (unexported)"
bash -c "func3"

# Func 4 was a new function in subshell and was exported,
echo "Calling func4 (exported in subshell)"
bash -c "func4"

echo "Calling aliases"
alias1
alias2
alias3
=== expected ===
0
# Capture in subshell!
--- Delta in subshell START ---
unalias alias1
###REENV###
unset -f func1
###REENV###
unset -v var1
###REENV###
#a:alias3(alias)
alias alias3='echo alias3'
###REENV###
#f:func2()
func2 () 
{ 
    echo not ok
}
declare -fx func2
###REENV###
#f:func3()
func3 () 
{ 
    echo not ok
}
###REENV###
#f:func4()
func4 () 
{ 
    echo not ok
}
declare -fx func4
###REENV###
#v:var2
declare -g -- var2="bbb"
###REENV###
#v:var3
declare -g -- var3=$'c\nc\nc'
###REENV###
0
--- Delta in subshell END ---
# Capture again, which should be empty
0
# Apply again!
0
# Capture after apply
unalias alias1
###REENV###
unset -f func1
###REENV###
unset -v var1
###REENV###
#a:alias3(alias)
alias alias3='echo alias3'
###REENV###
#f:func2()
func2 () 
{ 
    echo not ok
}
declare -fx func2
###REENV###
#f:func3()
func3 () 
{ 
    echo not ok
}
###REENV###
#f:func4()
func4 () 
{ 
    echo not ok
}
declare -fx func4
###REENV###
#v:var2
declare -g -- var2="bbb"
###REENV###
#v:var3
declare -g -- var3=$'c\nc\nc'
###REENV###
0
Calling func2
not ok
Calling func3
not ok
Calling func4
not ok
Calling func2 (exported)
not ok
Calling func2 (unexported)
bash: line 1: func3: command not found
Calling func4 (exported in subshell)
not ok
Calling aliases
reenv.bash.test: line ???: alias1: command not found
alias2
alias3
EOF

# ==========================================================
run_test "Help" <<'EOF'
reenv-base -h
echo $?
reenv-base --help
echo $?
reenv-cap -h
echo $?
reenv-cap --help
echo $?
=== expected ===

Reenv

Reenv tracks changes to the shell environment (variables, functions, and aliases)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell and replay
them in another.

Usage:
  reenv-base [-b BASELINE_NAME]
      Capture baseline state of the environment.
  reenv-cap [-b BASELINE_NAME] [-f CURRENT_NAME] [-o OUTPUT_FILE]
      Print environment delta since the baseline state.

Options:
  -b BASELINE_NAME  Specify baseline snapshot name (default is temporary file)
  -f CURRENT_NAME   Specify current snapshot name (default is temporary file)
  -o OUTPUT_FILE    Write the environment delta to OUTPUT_FILE instead of stdout

See https://github.com/omakoto/reenv for more details.

0

