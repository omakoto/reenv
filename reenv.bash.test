#!/bin/bash

. $(dirname "$0")/reenv.bash

num_tests=0
num_failure=0

function test() {
    (( ++num_tests))

    local label="$1"
    local run="$2"
    local expected="$3"

    echo "================"
    echo "Test: $label"
    echo "================"

    local actual="$(eval "$run" 2>&1)"
    rc=$?

    diff -Z -c <(echo -n "$expected") <(echo -n "$actual")
    rc=$?
    if (( $rc == 0 )); then
        echo "PASSED"
    else
        (( ++num_failure))
        echo "FAILED! Actual:"
        echo "------------"
        echo "$actual"
        echo "------------"
    fi
}

# ==========================================================
test "Call without base" '
reenv-cap
echo $?
' 'Use reenv-base to capture the base line environment first!
1'

# ==========================================================
test "No env change" '
reenv-base
echo $?
reenv-cap
echo $?
' '0
0
'

# ==========================================================
test "Basic env change" '

changed=orig
reenv-base
echo $?

aaa="abc"
export XXX="xyz def"
changed=new

reenv-cap
echo $?
# ----- end of eval -----
' '0
#XXX
declare -x XXX="xyz def"
#aaa
declare -- aaa="abc"
#changed
declare -- changed="new"
0
'

# ==========================================================
test "Basic env and func change" '

function a() { echo ok; }

reenv-base
echo $?

function a() { echo not ok; }
function b() { echo ok; }
var=xxx

reenv-cap
echo $?
# ----- end of eval -----
' '0
#a()
a () 
{ 
    echo not ok
}
#b()
b () 
{ 
    echo ok
}
#var
declare -- var="xxx"
0
'

# ==========================================================
test "Deletion" '

var1=aaa
var2=bbb
function func1() { echo ok; }
function func2() { echo ok; }

reenv-base
echo $?

unset -v var1
var2=bbb
var3=ccc
unset -f func1
function func2() { echo not ok; }
function func3() { echo not ok; }
reenv-cap
echo $?
# ----- end of eval -----
' '0
unset -f "func1"
unset -v "var1"
#func2()
func2 () 
{ 
    echo not ok
}
#func3()
func3 () 
{ 
    echo not ok
}
#var3
declare -- var3="ccc"
0
'

# ==========================================================
test "Actually apply" '

var1=aaa
var2=bbb
function func1() { echo ok; }
function func2() { echo ok; }

# Also try exporing the functions
export -f func1
export -f func2

reenv-base
echo $?

# Update the env in subshell, and dump the diff.
(
    echo "# Capture in subshell!"
    unset -v var1
    var2=bbb
    var3=ccc
    unset -f func1
    function func2() { echo not ok; }
    function func3() { echo not ok; }

    # Export a new function
    # BUG: This will be in the delta, but it will not be
    # exported.
    function func4() { echo not ok; }
    export -f func4

    reenv-cap > /tmp/reenv-test.sh
    cat /tmp/reenv-test.sh
    echo $?
)

echo "# Capture again, which should be empty"
reenv-cap
echo $?

echo "# Apply again!"
. /tmp/reenv-test.sh
echo $?

# Now, this should print the same delta.
reenv-cap
echo $?

# Try calling func2 and func3
echo "Calling func2"
func2

echo "Calling func3"
func3

echo "Calling func4"
func4

# func2 is exported, so it is visible from child procs
echo "Calling func2 (exported)"
bash -c "func2"

# func3 is exported, so it is not visible.
echo "Calling func2 (unexported)"
bash -c "func3"


# Func 4 was a new method in subshell and was exported,
# so it should be visible from child procs, but it will not, for now.
echo "Calling func4 (exported in subshell)"
bash -c "func4"
# ----- end of eval -----
' '0
# Capture in subshell!
unset -f "func1"
unset -v "var1"
#func2()
func2 () 
{ 
    echo not ok
}
#func3()
func3 () 
{ 
    echo not ok
}
#func4()
func4 () 
{ 
    echo not ok
}
#var3
declare -- var3="ccc"
0
# Capture again, which should be empty
0
# Apply again!
0
unset -f "func1"
unset -v "var1"
#func2()
func2 () 
{ 
    echo not ok
}
#func3()
func3 () 
{ 
    echo not ok
}
#func4()
func4 () 
{ 
    echo not ok
}
#var3
declare -- var3="ccc"
0
Calling func2
not ok
Calling func3
not ok
Calling func4
not ok
Calling func2 (exported)
not ok
Calling func2 (unexported)
bash: line 1: func3: command not found
Calling func4 (exported in subshell)
bash: line 1: func4: command not found
'


# ==========================================================
if (( $num_failure == 0 )) && (( $num_tests > 0 )) ; then
    echo "ALL TESTS PASSED!"
    exit 0
fi

echo "$(( $num_failure )) / $(( $num_tests )) TESTS FAILED!"
exit 1
