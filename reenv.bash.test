#!/bin/bash

. $(dirname "$0")/reenv.bash

num_tests=0
num_failure=0

DIFF=/usr/bin/diff

function green() {
    echo -en "\033[0;32m${*}\033[0m"
}

function red() {
    echo -en "\033[0;31m${*}\033[0m"
}

function test() {
    (( ++num_tests))

    local label="$1"
    local run="$2"
    local expected="$3"

    echo "================"
    green "Test:"
    echo " $label"
    echo "----------------"

    local actual="$(eval "$run" 2>&1)"
    rc=$?

    $DIFF -Z -u <(echo -n "$expected") <(echo -n "$actual")
    rc=$?
    if (( $rc == 0 )); then
        green "PASSED"
        echo
    else
        (( ++num_failure))
        red "FAILED!"
        echo " Actual result:"
        echo "#################################################################"
        echo "$actual"
        echo "#################################################################"
    fi
}

export _reenv_quiet=1

# ==========================================================
test "Call without base" '
reenv-cap
echo $?
' 'reenv: Use reenv-base to capture the base line environment first!
1'


# ==========================================================
_reenv_quiet=0 test "No quiet base" '
reenv-base
echo $?
' 'reenv: Captured baseline. Use reenv-cap to print the delta.
0
'

# ==========================================================
test "No env change" '
reenv-base
echo $?
reenv-cap
echo $?
' '0
0
'

# ==========================================================
test "Basic env change" '

changed=orig
reenv-base
echo $?

aaa="abc"
export XXX="xyz def"
changed=new

reenv-cap
echo $?
# ----- end of eval -----
' '0
#XXX
declare -g -x XXX="xyz def"
#aaa
declare -g -- aaa="abc"
#changed
declare -g -- changed="new"
0
'

# ==========================================================
test "Complex change" "$(cat <<EOF

function a() {
    echo ok
}
alias AAA="
echo OK
"

reenv-base
echo $?

function a() { echo not ok; }
function b() {
    echo "ok😄"
}
var="X
Y
Z"

alias BBB="
    echo BBB
"

reenv-cap
echo $?
EOF
# ---------------------------- end of eval -----------------------------
)" "$(cat <<EOF
0
#BBB (alias)
alias BBB='
    echo BBB
'
#a()
a () 
{ 
    echo not ok
}
#b()
b () 
{ 
    echo "ok😄"
}
#var
declare -g -- var=$'X\nY\nZ'
0
EOF
)"

# ==========================================================
test "Deletion" '

var1=aaa
var2=bbb
function func1() { echo ok; }
function func2() { echo ok; }
alias alias1="echo ok"
alias alias2="echo ok"

reenv-base
echo $?

unset -v var1
var2=bbb
var3=ccc
unset -f func1
unalias alias2
function func2() { echo not ok; }
function func3() { echo not ok; }

reenv-cap
echo $?
# ----- end of eval -----
' '0
unalias "alias2"
unset -f "func1"
unset -v "var1"
#func2()
func2 () 
{ 
    echo not ok
}
#func3()
func3 () 
{ 
    echo not ok
}
#var3
declare -g -- var3="ccc"
0
'

# ==========================================================
test "Actually apply" "$(cat <<EOF
shopt -s expand_aliases # Need this to execute aliases in here

var1=aaa
var2="b
b
b"
function func1() { echo ok; }
function func2() {
    echo ok
}

# Also try exporting the functions
export -f func1
export -f func2

alias alias1="echo alias1"
alias alias2="echo alias2"

reenv-base
echo $?

# Update the env in subshell, and dump the diff.
(
    echo "# Capture in subshell!"
    unset -v var1
    var2=bbb
    var3="c
c
c"
    unset -f func1
    function func2() { echo not ok; }
    function func3() { echo not ok; }


    # Export a new function.
    function func4() { echo not ok; }
    export -f func4

    # Change aliases
    unalias alias1
    alias alias3="echo alias3"

    reenv-cap > /tmp/reenv-test.sh
    echo "--- Delta in subshell START ---"
    cat /tmp/reenv-test.sh
    echo $?
    echo "--- Delta in subshell END ---"
)

echo "# Capture again, which should be empty"
reenv-cap
echo $?

echo "# Apply again!"
# Apply in a function, to make sure variables are declared as global.
# The reenv_ function name prefix is to avoid printing this method
# in a subsequent dump.
function reenv_test_apply_func() {
    . /tmp/reenv-test.sh
    echo $?
}
reenv_test_apply_func

echo "# Capture after apply"
# Now, this should print the same delta.
reenv-cap
echo $?

# Try calling func2 and func3
echo "Calling func2"
func2

echo "Calling func3"
func3

echo "Calling func4"
func4

# func2 is exported, so it is visible from child procs
echo "Calling func2 (exported)"
bash -c "func2"

# func3 is exported, so it is not visible.
echo "Calling func2 (unexported)"
bash -c "func3"

# Func 4 was a new function in subshell and was exported,
echo "Calling func4 (exported in subshell)"
bash -c "func4"

echo "Calling aliases"
alias1
alias2
alias3

EOF
# ---------------------------- end of eval -----------------------------
)" "$(cat <<EOF
0
# Capture in subshell!
--- Delta in subshell START ---
unalias "alias1"
unset -f "func1"
unset -v "var1"
#alias3 (alias)
alias alias3='echo alias3'
#func2()
func2 () 
{ 
    echo not ok
}
declare -fx func2
#func3()
func3 () 
{ 
    echo not ok
}
#func4()
func4 () 
{ 
    echo not ok
}
declare -fx func4
#var2
declare -g -- var2="bbb"
#var3
declare -g -- var3=$'c\nc\nc'
0
--- Delta in subshell END ---
# Capture again, which should be empty
0
# Apply again!
0
# Capture after apply
unalias "alias1"
unset -f "func1"
unset -v "var1"
#alias3 (alias)
alias alias3='echo alias3'
#func2()
func2 () 
{ 
    echo not ok
}
declare -fx func2
#func3()
func3 () 
{ 
    echo not ok
}
#func4()
func4 () 
{ 
    echo not ok
}
declare -fx func4
#var2
declare -g -- var2="bbb"
#var3
declare -g -- var3=$'c\nc\nc'
0
Calling func2
not ok
Calling func3
not ok
Calling func4
not ok
Calling func2 (exported)
not ok
Calling func2 (unexported)
bash: line 1: func3: command not found
Calling func4 (exported in subshell)
not ok
Calling aliases
./reenv.bash.test: line 121: alias1: command not found
alias2
alias3
EOF
)"

# ==========================================================
test "Help" '
reenv-base -h
echo $?
reenv-base --help
echo $?
reenv-cap -h
echo $?
reenv-cap --help
echo $?
# ----- end of eval -----
' '
Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell (or subshell)
and replay them in another.

See https://github.com/omakoto/reenv for more details.

1

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell (or subshell)
and replay them in another.

See https://github.com/omakoto/reenv for more details.

1

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell (or subshell)
and replay them in another.

See https://github.com/omakoto/reenv for more details.

1

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell (or subshell)
and replay them in another.

See https://github.com/omakoto/reenv for more details.

1
'

# ==========================================================
test "Precheck success" '
_reenv_pre_check
echo $?
# ----- end of eval -----
' '0
'

# ==========================================================
PATH=./ test "Precheck fail" '
_reenv_pre_check
echo $?
# ----- end of eval -----
' 'reenv: Requires `comm` command. Install with `atp install coreutils`.
1
'

# ==========================================================
test "Custom skip" '
reenv-base

REENV_SKIP="(2XXX|3YYY)"
var1="abc"
var2="def"
var2XXX="xyz"
func1() {
    :
}
func2() {
    :
}
func3YYY() {
    :
}

reenv-cap
echo $?
# ----- end of eval -----
' '#func1()
func1 () 
{ 
    :
}
#func2()
func2 () 
{ 
    :
}
#var1
declare -g -- var1="abc"
#var2
declare -g -- var2="def"
0
'


# ==========================================================
if (( $num_failure == 0 )) && (( $num_tests > 0 )) ; then
    green "ALL TESTS PASSED!"
    echo
    exit 0
fi

red "$(( $num_failure )) / $(( $num_tests )) TESTS FAILED!"
echo
exit 1
