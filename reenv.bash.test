#!/bin/bash

. $(dirname "$0")/reenv.bash

num_tests=0
num_failure=0

DIFF=/usr/bin/diff

function green() {
    echo -en "\033[0;32m${*}\033[0m"
}

function red() {
    echo -en "\033[0;31m${*}\033[0m"
}

function test() {
    (( ++num_tests))

    local label="$1"

    local content
    IFS='' read -r -d '' content

    local run="${content%%$'\n'=== expected ===*}"
    local expected="${content#*=== expected ===}"
    expected="${expected#?}"

    echo "================"
    green "Test:"
    echo " $label"
    echo "----------------"

    local actual="$(eval "$run" 2>&1)"
    rc=$?

    $DIFF -Z -u <(echo -n "$expected") <(echo -n "$actual")
    rc=$?
    if (( $rc == 0 )); then
        green "PASSED"
        echo
    else
        (( ++num_failure))
        red "FAILED!"
        echo " Actual result:"
        echo "#################################################################"
        echo "$actual"
        echo "#################################################################"
    fi
}

export _reenv_quiet=1

# ==========================================================
test "Call without base" <<'EOF'
reenv-cap
echo $?
=== expected ===
reenv: Use reenv-base to capture the base line environment first!
1
EOF


# ==========================================================
_reenv_quiet=0 test "No quiet base" <<'EOF'
reenv-base
echo $?
=== expected ===
reenv: Captured baseline. Use reenv-cap to print the delta.
0
EOF

# ==========================================================
test "No env change" <<'EOF'
reenv-base
echo $?
reenv-cap
echo $?
=== expected ===
0
0
EOF

# ==========================================================
test "Basic env change" <<'EOF'
changed=orig
reenv-base
echo $?

aaa="abc"
export XXX="xyz def"
changed=new

reenv-cap
echo $?
=== expected ===
0
#v:XXX
declare -g -x XXX="xyz def"
#v:aaa
declare -g -- aaa="abc"
#v:changed
declare -g -- changed="new"
0
EOF

# ==========================================================
test "Complex change" <<'EOF'

function a() {
    echo ok
}
alias AAA="
echo OK
"

reenv-base
echo $?

function a() { echo not ok; }
function b() {
    echo "ok😄"
}
var="X
Y
Z"

alias BBB="
    echo BBB
"

reenv-cap
echo $?
=== expected ===
0
#a:BBB(alias)
alias BBB='
    echo BBB
'
#f:a()
a () 
{ 
    echo not ok
}
#f:b()
b () 
{ 
    echo "ok😄"
}
#v:var
declare -g -- var=$'X\nY\nZ'
0
EOF

# ==========================================================
test "Deletion" <<'EOF'
var1=aaa
var2=bbb
function func1() { echo ok; }
function func2() { echo ok; }
alias alias1="echo ok"
alias alias2="echo ok"

reenv-base
echo $?

unset -v var1
var2=bbb
var3=ccc
unset -f func1
unalias alias2
function func2() { echo not ok; }
function func3() { echo not ok; }

reenv-cap
echo $?
=== expected ===
0
unalias alias2
unset -f func1
unset -v var1
#f:func2()
func2 () 
{ 
    echo not ok
}
#f:func3()
func3 () 
{ 
    echo not ok
}
#v:var3
declare -g -- var3="ccc"
0
EOF

# ==========================================================
test "Actually apply" <<'EOF'
shopt -s expand_aliases # Need this to execute aliases in here

var1=aaa
var2="b
b
b"
function func1() { echo ok; }
function func2() {
    echo ok
}

# Also try exporting the functions
export -f func1
export -f func2

alias alias1="echo alias1"
alias alias2="echo alias2"

reenv-base
echo $?

# Update the env in subshell, and dump the diff.
(
    echo "# Capture in subshell!"
    unset -v var1
    var2=bbb
    var3="c
c
c"
    unset -f func1
    function func2() { echo not ok; }
    function func3() { echo not ok; }


    # Export a new function.
    function func4() { echo not ok; }
    export -f func4

    # Change aliases
    unalias alias1
    alias alias3="echo alias3"

    reenv-cap > /tmp/reenv-test.sh
    echo "--- Delta in subshell START ---"
    cat /tmp/reenv-test.sh
    echo $?
    echo "--- Delta in subshell END ---"
)

echo "# Capture again, which should be empty"
reenv-cap
echo $?

echo "# Apply again!"
# Apply in a function, to make sure variables are declared as global.
# The reenv_ function name prefix is to avoid printing this method
# in a subsequent dump.
function reenv_test_apply_func() {
    . /tmp/reenv-test.sh
    echo $?
}
reenv_test_apply_func

echo "# Capture after apply"
# Now, this should print the same delta.
reenv-cap
echo $?

# Try calling func2 and func3
echo "Calling func2"
func2

echo "Calling func3"
func3

echo "Calling func4"
func4

# func2 is exported, so it is visible from child procs
echo "Calling func2 (exported)"
bash -c "func2"

# func3 is exported, so it is not visible.
echo "Calling func2 (unexported)"
bash -c "func3"

# Func 4 was a new function in subshell and was exported,
echo "Calling func4 (exported in subshell)"
bash -c "func4"

echo "Calling aliases"
alias1
alias2
alias3
=== expected ===
0
# Capture in subshell!
--- Delta in subshell START ---
unalias alias1
unset -f func1
unset -v var1
#a:alias3(alias)
alias alias3='echo alias3'
#f:func2()
func2 () 
{ 
    echo not ok
}
declare -fx func2
#f:func3()
func3 () 
{ 
    echo not ok
}
#f:func4()
func4 () 
{ 
    echo not ok
}
declare -fx func4
#v:var2
declare -g -- var2="bbb"
#v:var3
declare -g -- var3=$'c\nc\nc'
0
--- Delta in subshell END ---
# Capture again, which should be empty
0
# Apply again!
0
# Capture after apply
unalias alias1
unset -f func1
unset -v var1
#a:alias3(alias)
alias alias3='echo alias3'
#f:func2()
func2 () 
{ 
    echo not ok
}
declare -fx func2
#f:func3()
func3 () 
{ 
    echo not ok
}
#f:func4()
func4 () 
{ 
    echo not ok
}
declare -fx func4
#v:var2
declare -g -- var2="bbb"
#v:var3
declare -g -- var3=$'c\nc\nc'
0
Calling func2
not ok
Calling func3
not ok
Calling func4
not ok
Calling func2 (exported)
not ok
Calling func2 (unexported)
bash: line 1: func3: command not found
Calling func4 (exported in subshell)
not ok
Calling aliases
./reenv.bash.test: line 126: alias1: command not found
alias2
alias3
EOF

# ==========================================================
test "Help" <<'EOF'
reenv-base -h
echo $?
reenv-base --help
echo $?
reenv-cap -h
echo $?
reenv-cap --help
echo $?
=== expected ===

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell and replay
them in another.

See https://github.com/omakoto/reenv for more details.

1

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell and replay
them in another.

See https://github.com/omakoto/reenv for more details.

1

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell and replay
them in another.

See https://github.com/omakoto/reenv for more details.

1

Reenv

Reenv tracks changes to the shell environment (variables and functions)
between two points in time and emits them as sourceable bash code.
This lets you capture environment changes made in one shell and replay
them in another.

See https://github.com/omakoto/reenv for more details.

1
EOF

# ==========================================================
test "Precheck success" <<'EOF'
_reenv_pre_check
echo $?
=== expected ===
0
EOF

# ==========================================================
PATH=./ test "Precheck fail" <<'EOF'
_reenv_pre_check
echo $?
=== expected ===
reenv: Requires `comm` command. Install with `apt install coreutils`.
1
EOF

# ==========================================================
test "Custom skip" <<'EOF'
reenv-base

REENV_SKIP="(2XXX|3YYY)"
var1="abc"
var2="def"
var2XXX="xyz"
func1() {
    :
}
func2() {
    :
}
func3YYY() {
    :
}

reenv-cap
echo $?
=== expected ===
#f:func1()
func1 () 
{ 
    :
}
#f:func2()
func2 () 
{ 
    :
}
#v:var1
declare -g -- var1="abc"
#v:var2
declare -g -- var2="def"
0
EOF


# ==========================================================
test "Quoting in deletion" <<'EOF'
# '[' is a valid function name in Bash but requires escaping.
function [ () { :; }

reenv-base
echo $?

unset -f [

reenv-cap
echo $?
=== expected ===
0
unset -f \[
0
EOF


test "Comm fallback" <<'EOF'
export var_to_del="bye"
reenv-base
echo $?

unset var_to_del
export var_to_add="hello"
export REENV_USE_COMM_FALLBACK=1

reenv-cap
echo $?
=== expected ===
0
unset -v var_to_del
#v:var_to_add
declare -g -x var_to_add="hello"
0
EOF


test "Readonly override robustness" <<'EOF'
# 1. Baseline
reenv-base > /dev/null

# 2. Capture in subshell (variable is new there)
(
    readonly my_readonly="captured"
    zz_after="captured"
    reenv-cap > /tmp/reenv-robust.sh
)

# 3. Parent shell setup (pre-existing readonly with different value)
readonly my_readonly="original"

# 4. Apply the captured script
# We want to see the error message this time.
source /tmp/reenv-robust.sh

# 5. Verify results
echo "my_readonly: $my_readonly"
echo "zz_after: $zz_after"
=== expected ===
/tmp/reenv-robust.sh: line 2: declare: my_readonly: readonly variable
my_readonly: original
zz_after: captured
EOF


test "Change REENV_SKIP after base" <<'EOF'
# 1. Baseline
reenv-base > /dev/null

# 2. Set a variable and then decide to skip it
export skip_me="secret"
export keep_me="hello"
export REENV_SKIP="skip_me"

# 3. Capture
reenv-cap
=== expected ===
#v:keep_me
declare -g -x keep_me="hello"
EOF


# ==========================================================
if (( $num_failure == 0 )) && (( $num_tests > 0 )) ; then
    green "ALL TESTS PASSED!"
    echo
    exit 0
fi

red "$(( $num_failure )) / $(( $num_tests )) TESTS FAILED!"
echo
exit 1
