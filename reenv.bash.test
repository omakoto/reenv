# ==========================================================
run_test "Precheck success" <<'EOF'
_reenv_pre_check
echo $?
=== expected ===
0
EOF

# ==========================================================
PATH=./ run_test "Precheck fail" <<'EOF'
_reenv_pre_check
echo $?
=== expected ===
reenv: Requires `python3`.
1
EOF

# ==========================================================
run_test "Custom skip" <<'EOF'
reenv-base

REENV_SKIP="(2XXX|3YYY)"
var1="abc"
var2="def"
var2XXX="xyz"
func1() {
    :
}
func2() {
    :
}
func3YYY() {
    :
}

reenv-cap
echo $?
=== expected ===
#f:func1()
func1 () 
{ 
    :
}
###REENV###
#f:func2()
func2 () 
{ 
    :
}
###REENV###
#v:var1
declare -g -- var1="abc"
###REENV###
#v:var2
declare -g -- var2="def"
###REENV###
0
EOF


# ==========================================================
run_test "Implicit skip" <<'EOF'
reenv-base
echo $?

IFS=":"
RANDOM=123
SECONDS=456
USER="another_user"
PWD="/another/pwd"
OLDPWD="/another/oldpwd"
SHLVL=99
BASH_SOME_VAR="bash"
reenv_some_var="reenv"

var_captured="should_capture"

reenv-cap
echo $?
=== expected ===
0
#v:var_captured
declare -g -- var_captured="should_capture"
###REENV###
0
EOF


# ==========================================================
run_test "Quoting in deletion" <<'EOF'
# '[' is a valid function name in Bash but requires escaping.
function [ () { :; }

reenv-base
echo $?

unset -f [

reenv-cap
echo $?
=== expected ===
0
unset -f \[
###REENV###
0
EOF


run_test "Readonly override robustness" <<'EOF'
# 1. Baseline
reenv-base > /dev/null

# 2. Capture in subshell (variable is new there)
(
    readonly my_readonly="captured"
    zz_after="captured"
    reenv-cap > /tmp/reenv-robust.sh
)

# 3. Parent shell setup (pre-existing readonly with different value)
readonly my_readonly="original"

# 4. Apply the captured script
# We want to see the error message this time.
source /tmp/reenv-robust.sh

# 5. Verify results
echo "my_readonly: $my_readonly"
echo "zz_after: $zz_after"
=== expected ===
/tmp/reenv-robust.sh: line 2: declare: my_readonly: readonly variable
my_readonly: original
zz_after: captured
EOF


run_test "Change REENV_SKIP after base" <<'EOF'
# 1. Baseline
reenv-base > /dev/null

# 2. Set a variable and then decide to skip it
export skip_me="secret"
export keep_me="hello"
export REENV_SKIP="skip_me"

# 3. Capture
reenv-cap
=== expected ===
#v:keep_me
declare -g -x keep_me="hello"
###REENV###
EOF


# ==========================================================
run_test "set -u robustness" <<'EOF'
set -u
reenv-base > /dev/null
echo "base $?"
my_var="hello"
reenv-cap
echo "cap $?"
set +u
=== expected ===
base 0
#v:my_var
declare -g -- my_var="hello"
###REENV###
cap 0
EOF


# ==========================================================
run_test "-b and -f options" <<'EOF'
my_base="/tmp/test_base"
my_cap="/tmp/test_cap"
# Ensure we clean up any previous files
rm -f "${my_base}.sh" "${my_base}-clear.sh" "${my_cap}.sh" "${my_cap}-clear.sh"

changed=orig
reenv-base -b "$my_base"
echo $?

# Verify base files were created and are not empty
if [[ -s "${my_base}.sh" && -s "${my_base}-clear.sh" ]]; then
    echo "Base files created successfully"
else
    echo "Base files missing or empty"
fi

aaa="abc"
export XXX="xyz def"
changed=new

# Run cap with -b and -f
reenv-cap -b "$my_base" -f "$my_cap"
echo $?

# Verify cap files were created and are not empty
if [[ -s "${my_cap}.sh" && -s "${my_cap}-clear.sh" ]]; then
    echo "Cap files created successfully"
else
    echo "Cap files missing or empty"
fi

# Clean up
rm -f "${my_base}.sh" "${my_base}-clear.sh" "${my_cap}.sh" "${my_cap}-clear.sh"
=== expected ===
0
Base files created successfully
#v:XXX
declare -g -x XXX="xyz def"
###REENV###
#v:aaa
declare -g -- aaa="abc"
###REENV###
#v:changed
declare -g -- changed="new"
###REENV###
0
Cap files created successfully
EOF

# ==========================================================
run_test "-b and -f options invalid cases" <<'EOF'
# 1. Invalid option to reenv-base
reenv-base -z
echo $?

# 2. Unexpected positional argument to reenv-base
reenv-base -b /tmp/foo extra_arg
echo $?

# 3. Missing base file for reenv-cap
reenv-cap -b /tmp/nonexistent_base
echo $?

# 4. Invalid option to reenv-cap
reenv-cap -z
echo $?
=== expected ===
getopt: invalid option -- 'z'
1
reenv: Unexpected argument: extra_arg
1
reenv: Use reenv-base to capture the base line environment first!
1
getopt: invalid option -- 'z'
1
EOF


# ==========================================================
run_test "-o option for reenv-cap" <<'EOF'
my_out="/tmp/reenv-test-out.sh"
rm -f "$my_out"

changed=orig
reenv-base
echo $?

aaa="abc"
export XXX="xyz def"
changed=new

# Run cap with -o
reenv-cap -o "$my_out"
echo $?

# Verify output is empty and redirected to the file
if [[ -f "$my_out" ]]; then
    echo "Output file created"
    cat "$my_out"
else
    echo "Output file NOT created"
fi

# Clean up
rm -f "$my_out"
=== expected ===
0
0
Output file created
#v:XXX
declare -g -x XXX="xyz def"
###REENV###
#v:aaa
declare -g -- aaa="abc"
###REENV###
#v:changed
declare -g -- changed="new"
###REENV###
EOF


# ==========================================================
run_test "reenv-comm option combos" <<'EOF'
file1="/tmp/comm_test1"
file2="/tmp/comm_test2"
echo -n -e "A\n###REENV###\nB\n###REENV###\n" > "$file1"
echo -n -e "B\n###REENV###\nC\n###REENV###\n" > "$file2"

# 1. No options
echo "=== No options ==="
reenv-comm "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 2. Option -1
echo "=== Option -1 ==="
reenv-comm -1 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 3. Option -2
echo "=== Option -2 ==="
reenv-comm -2 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 4. Option -3
echo "=== Option -3 ==="
reenv-comm -3 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 5. Option -12
echo "=== Option -12 ==="
reenv-comm -12 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 6. Option -13
echo "=== Option -13 ==="
reenv-comm -13 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 7. Option -23
echo "=== Option -23 ==="
reenv-comm -23 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 8. Option -2 -3
echo "=== Option -2 -3 ==="
reenv-comm -2 -3 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 9. Option -123
echo "=== Option -123 ==="
reenv-comm -123 "$file1" "$file2" | sed -e 's/\t/[TAB]/g'

# 10. Invalid option
echo "=== Option -z ==="
reenv-comm -z "$file1" "$file2" 2>&1
echo $?

# 11. Missing arguments (1 file)
echo "=== 1 file ==="
reenv-comm "$file1" 2>&1
echo $?

# 12. Missing arguments (no files)
echo "=== no files ==="
reenv-comm 2>&1
echo $?

# 13. Help option -h
echo "=== Option -h ==="
reenv-comm -h 2>&1
echo $?

# 14. Help option --help
echo "=== Option --help ==="
reenv-comm --help 2>&1
echo $?

rm -f "$file1" "$file2"
=== expected ===
=== No options ===
A
###REENV###
[TAB][TAB]B
###REENV###
[TAB]C
###REENV###
=== Option -1 ===
[TAB]B
###REENV###
C
###REENV###
=== Option -2 ===
A
###REENV###
[TAB]B
###REENV###
=== Option -3 ===
A
###REENV###
[TAB]C
###REENV###
=== Option -12 ===
B
###REENV###
=== Option -13 ===
C
###REENV###
=== Option -23 ===
A
###REENV###
=== Option -2 -3 ===
A
###REENV###
=== Option -123 ===
=== Option -z ===
reenv-comm: invalid option -- z
1
=== 1 file ===
Usage: reenv-comm [-1] [-2] [-3] <file1> <file2>
1
=== no files ===
Usage: reenv-comm [-1] [-2] [-3] <file1> <file2>
1
=== Option -h ===
comm(1) equivalent tool used by reenv
0
=== Option --help ===
comm(1) equivalent tool used by reenv
0
EOF


# ==========================================================
run_test "reenv-sort basic sorting" <<'EOF'
# 1. Unsorted single-line records
echo "=== Unsorted single-line ==="
echo -n -e "C\n###REENV###\nA\n###REENV###\nB\n###REENV###\n" | reenv-sort

# 2. Unsorted multiline records
echo "=== Unsorted multiline ==="
echo -n -e "Z\nline2\n###REENV###\nA\nline2\n###REENV###\n" | reenv-sort

# 3. Empty input
echo "=== Empty input ==="
echo -n "" | reenv-sort
echo $?

# 4. Help option -h
echo "=== Option -h ==="
reenv-sort -h 2>&1
echo $?

# 5. Help option --help
echo "=== Option --help ==="
reenv-sort --help 2>&1
echo $?
=== expected ===
=== Unsorted single-line ===
A
###REENV###
B
###REENV###
C
###REENV###
=== Unsorted multiline ===
A
line2
###REENV###
Z
line2
###REENV###
=== Empty input ===
0
=== Option -h ===
sort tool used by reenv
0
=== Option --help ===
sort tool used by reenv
0
EOF


# ==========================================================
run_test "Completions support" <<'EOF'
# Define dummy helper functions
_helper_old() { :; }
_helper_del() { :; }
_helper_skip() { :; }
_helper_add() { :; }
_helper_new() { :; }
_helper_default() { :; }
_helper_empty() { :; }

# Setup initial completions
complete -r cmd_add 2>/dev/null
complete -r cmd_mod 2>/dev/null
complete -r cmd_del 2>/dev/null
complete -r cmd_skip 2>/dev/null
complete -r /etc/init.d/plymouth-log 2>/dev/null
complete -r gg 2>/dev/null
complete -r go 2>/dev/null
complete -r builtin 2>/dev/null
complete -r slay 2>/dev/null
complete -r -D 2>/dev/null
complete -r -E 2>/dev/null

complete -F _helper_old cmd_mod
complete -F _helper_del cmd_del
complete -F _helper_skip cmd_skip
complete -F _comp_complete_service /etc/init.d/plymouth-log

export REENV_SKIP="cmd_skip"
reenv-base
echo "base $?"

# Modify completions
complete -F _helper_add cmd_add
complete -F _helper_new cmd_mod
complete -r cmd_del
complete -r /etc/init.d/plymouth-log
complete -o bashdefault -o filenames -F _git_meld_history gg
complete -C '/home/omakoto/go/bin/gocomplete' go
complete -b builtin
complete -u slay
complete -F _helper_default -D
complete -F _helper_empty -E

# Capture delta
reenv-cap > /tmp/reenv-test-comp.sh
echo "cap $?"

# Print delta content for assertion
cat /tmp/reenv-test-comp.sh

# Reset completions to a different state (or back to base)
complete -r cmd_add 2>/dev/null
complete -r cmd_mod 2>/dev/null
complete -r cmd_del 2>/dev/null
complete -r cmd_skip 2>/dev/null
complete -r /etc/init.d/plymouth-log 2>/dev/null
complete -r gg 2>/dev/null
complete -r go 2>/dev/null
complete -r builtin 2>/dev/null
complete -r slay 2>/dev/null
complete -r -D 2>/dev/null
complete -r -E 2>/dev/null

complete -F _helper_old cmd_mod
complete -F _helper_del cmd_del
complete -F _helper_skip cmd_skip
complete -F _comp_complete_service /etc/init.d/plymouth-log

# Apply the delta
source /tmp/reenv-test-comp.sh
echo "apply $?"

# Verify completions after applying
echo "--- Results ---"
complete -p /etc/init.d/plymouth-log 2>/dev/null || echo "plymouth-log not found"
complete -p cmd_add 2>/dev/null || echo "cmd_add not found"
complete -p cmd_mod 2>/dev/null || echo "cmd_mod not found"
complete -p cmd_del 2>/dev/null || echo "cmd_del not found"
complete -p cmd_skip 2>/dev/null || echo "cmd_skip not found"
complete -p gg 2>/dev/null || echo "gg not found"
complete -p go 2>/dev/null || echo "go not found"
complete -p builtin 2>/dev/null || echo "builtin not found"
complete -p slay 2>/dev/null || echo "slay not found"
complete -p -D 2>/dev/null || echo "default not found"
complete -p -E 2>/dev/null || echo "empty not found"

# Clean up
complete -r cmd_add 2>/dev/null
complete -r cmd_mod 2>/dev/null
complete -r cmd_del 2>/dev/null
complete -r cmd_skip 2>/dev/null
complete -r /etc/init.d/plymouth-log 2>/dev/null
complete -r gg 2>/dev/null
complete -r go 2>/dev/null
complete -r builtin 2>/dev/null
complete -r slay 2>/dev/null
complete -r -D 2>/dev/null
complete -r -E 2>/dev/null
unset REENV_SKIP
rm -f /tmp/reenv-test-comp.sh
=== expected ===
base 0
cap 0
complete -r /etc/init.d/plymouth-log
###REENV###
complete -r cmd_del
###REENV###
#c:-D(completion)
complete -F _helper_default -D
###REENV###
#c:-E(completion)
complete -F _helper_empty -E
###REENV###
#c:builtin(completion)
complete -b builtin
###REENV###
#c:cmd_add(completion)
complete -F _helper_add cmd_add
###REENV###
#c:cmd_mod(completion)
complete -F _helper_new cmd_mod
###REENV###
#c:gg(completion)
complete -o bashdefault -o filenames -F _git_meld_history gg
###REENV###
#c:go(completion)
complete -C '/home/omakoto/go/bin/gocomplete' go
###REENV###
#c:slay(completion)
complete -u slay
###REENV###
apply 0
--- Results ---
plymouth-log not found
complete -F _helper_add cmd_add
complete -F _helper_new cmd_mod
cmd_del not found
complete -F _helper_skip cmd_skip
complete -o bashdefault -o filenames -F _git_meld_history gg
complete -C '/home/omakoto/go/bin/gocomplete' go
complete -b builtin
complete -u slay
complete -F _helper_default -D
complete -F _helper_empty -E
EOF


# ==========================================================
run_test "Bind support" <<'EOF'
# Establish baseline
bind 'set completion-ignore-case off' 2>/dev/null
bind '"\C-x\C-b": accept-line' 2>/dev/null
bind '"\C-x\C-e": abort' 2>/dev/null

reenv-base
echo "base $?"

# Apply changes
bind 'set completion-ignore-case on' 2>/dev/null
bind '"\C-x\C-a": accept-line' 2>/dev/null
bind '"\C-x\C-b": abort' 2>/dev/null
bind '"\C-x\C-c": "macro output"' 2>/dev/null
bind -x '"\C-x\C-d": echo hello' 2>/dev/null
bind -r "\C-x\C-e" 2>/dev/null

reenv-cap > /tmp/reenv-test-bind.sh
cat /tmp/reenv-test-bind.sh

# Let's clean up/reset the bindings to see if the script restores them.
bind 'set completion-ignore-case off' 2>/dev/null
bind -r "\C-x\C-a" 2>/dev/null
bind '"\C-x\C-b": accept-line' 2>/dev/null
bind -r "\C-x\C-c" 2>/dev/null
bind -r "\C-x\C-d" 2>/dev/null
bind '"\C-x\C-e": abort' 2>/dev/null

# Source the generated cap output
. /tmp/reenv-test-bind.sh
echo "apply $?"

# Verify variables
bind -v 2>/dev/null | grep completion-ignore-case
# Verify bindings, macros, shell commands
bind -p 2>/dev/null | grep -E '\\C-x\\C-[ab]'
bind -s 2>/dev/null | grep '\\C-x\\C-c'
bind -X 2>/dev/null | grep '\\C-x\\C-d'

rm -f /tmp/reenv-test-bind.sh
=== expected ===
base 0
bind -r '\C-x\C-e' 2>/dev/null
###REENV###
#b:key:"\C-x\C-a"
bind '"\C-x\C-a": accept-line' 2>/dev/null
###REENV###
#b:key:"\C-x\C-b"
bind '"\C-x\C-b": abort' 2>/dev/null
###REENV###
#b:macro:"\C-x\C-c"
bind '"\C-x\C-c": "macro output"' 2>/dev/null
###REENV###
#b:var:completion-ignore-case
bind 'set completion-ignore-case on' 2>/dev/null
###REENV###
#b:x:"\C-x\C-d"
bind -x '"\C-x\C-d": echo hello' 2>/dev/null
###REENV###
apply 0
set completion-ignore-case on
"\C-x\C-b": abort
"\C-x\C-a": accept-line
"\C-x\C-c": "macro output"
"\C-x\C-d" "echo hello"
EOF


# ==========================================================
if (( $num_failure == 0 )) && (( $num_tests > 0 )) ; then
    green "ALL TESTS PASSED!"
    echo
    exit 0
fi

red "$(( $num_failure )) / $(( $num_tests )) TESTS FAILED!"
echo
exit 1
